# 生产环境变量(复制成 .env.prod 后填值,不进 Git)
# cp .env.prod.example .env.prod && edit .env.prod

# --- Database ---
MYSQL_DATABASE=meaning_log
MYSQL_USER=meaning_log
MYSQL_PASSWORD=change-me-strong-password
MYSQL_ROOT_PASSWORD=change-me-root-password

# --- RabbitMQ ---
RABBITMQ_USERNAME=meaning_log
RABBITMQ_PASSWORD=change-me-mq-password

# --- Auth ---
# 生成: openssl rand -base64 32
JWT_SECRET=CHANGE-ME-32-BYTES-BASE64-ENCODED

# --- AI (DeepSeek) ---
DEEPSEEK_API_KEY=sk-xxx
APP_AI_MODEL=deepseek-chat
APP_AI_BASE_URL=https://api.deepseek.com/v1

# --- Mail (Resend) ---
MAIL_HOST=smtp.resend.com
MAIL_PORT=2465
MAIL_USERNAME=resend
MAIL_PASSWORD=re_xxx
MAIL_FROM=noreply@yourdomain.com

# --- CORS: 前端域名追加白名单 ---
# 逗号分隔,例如: https://meaning-log.vercel.app,https://han.zhaisir.com
APP_CORS_ADDITIONAL_ORIGINS=
