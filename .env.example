# Local runtime settings. Copy this file to .env and replace placeholders.
MYSQL_DATABASE=meaning_log
MYSQL_USER=meaning_log
MYSQL_PASSWORD=meaning-log-local-password
MYSQL_ROOT_PASSWORD=meaning-log-root-password
MYSQL_PORT=3306
REDIS_PORT=6379

# Resend SMTP settings. MAIL_FROM must use a verified Resend domain.
MAIL_HOST=smtp.resend.com
MAIL_PORT=2465
MAIL_USERNAME=resend
MAIL_PASSWORD=your-resend-api-key
MAIL_FROM=noreply@your-verified-domain.example
MAIL_SMTP_SSL_ENABLE=true
MAIL_SMTP_STARTTLS_ENABLE=false
MAIL_CONNECTION_TIMEOUT_MS=10000
MAIL_READ_TIMEOUT_MS=10000
MAIL_WRITE_TIMEOUT_MS=10000
